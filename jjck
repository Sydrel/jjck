<!DOCTYPE html>
<html lang="en-US">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JJCK Collectibles | Premium Sports Cards & Collectibles</title>
    <meta name="description" content="Discover JJCK Collectibles, the Treasure Coast's ultimate family-owned shop for sports cards, Pokémon, One Piece, Magic, Lorcana & more.">
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* ============================
                   CSS VARIABLES - BLACK & WHITE ONLY
                ============================ */
        :root {
            --bg-dark: #000000;
            --bg-card: #0a0a0a;
            --bg-card-hover: #141414;
            --bg-light: #1a1a1a;
            --bg-gray: #222222;
            --bg-off-white: #f5f5f5;
            
            --text-primary: #ffffff;
            --text-secondary: #bbbbbb;
            --text-muted: #777777;
            --text-dark: #000000;
            
            --border-subtle: rgba(255,255,255,0.06);
            --border-medium: rgba(255,255,255,0.12);
            
            --shadow-glow: 0 0 60px rgba(255,255,255,0.03);
            
            --font-heading: 'Oswald', sans-serif;
            --font-body: 'Roboto', sans-serif;
            
            --radius: 12px;
            --transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }
        
        /* ============================
                   RESET & BASE
                ============================ */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        html {
            scroll-behavior: smooth;
        }
        
        body {
            font-family: var(--font-body);
            background: var(--bg-dark);
            color: var(--text-secondary);
            line-height: 1.7;
            -webkit-font-smoothing: antialiased;
        }
        
        img {
            max-width: 100%;
            height: auto;
            display: block;
        }
        
        a {
            text-decoration: none;
            color: inherit;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
        }
        
        /* ============================
                   SCROLLBAR
                ============================ */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: var(--bg-dark);
        }
        ::-webkit-scrollbar-thumb {
            background: var(--text-muted);
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: var(--text-secondary);
        }
        
        /* ============================
                   BUTTONS - B&W ONLY
                ============================ */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 16px 36px;
            font-family: var(--font-heading);
            font-weight: 600;
            font-size: 15px;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            transition: var(--transition);
            position: relative;
            overflow: hidden;
        }
        
        .btn-primary {
            background: var(--text-primary);
            color: var(--text-dark);
        }
        
        .btn-primary:hover {
            background: var(--text-secondary);
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(255,255,255,0.15);
        }
        
        .btn-outline {
            background: transparent;
            color: var(--text-primary);
            border: 2px solid var(--text-muted);
        }
        
        .btn-outline:hover {
            border-color: var(--text-primary);
            background: rgba(255,255,255,0.05);
            transform: translateY(-3px);
        }
        
        .btn-small {
            padding: 10px 24px;
            font-size: 12px;
        }
        
        /* ============================
                   SECTION HEADERS
                ============================ */
        .section-header {
            text-align: center;
            margin-bottom: 56px;
        }
        
        .section-header .tag {
            display: inline-block;
            font-family: var(--font-heading);
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 3px;
            color: var(--text-muted);
            margin-bottom: 8px;
        }
        
        .section-header h2 {
            font-family: var(--font-heading);
            font-size: clamp(32px, 4.5vw, 48px);
            font-weight: 700;
            color: var(--text-primary);
            line-height: 1.1;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        
        .section-header h2 .highlight {
            color: var(--text-secondary);
        }
        
        .section-header p {
            max-width: 580px;
            margin: 12px auto 0;
            color: var(--text-muted);
            font-size: 17px;
        }
        
        .section-header .line {
            width: 60px;
            height: 3px;
            background: var(--text-primary);
            margin: 16px auto 0;
        }
        
        /* ============================
                   HEADER / NAV
                ============================ */
        .header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            padding: 16px 0;
            transition: var(--transition);
            background: transparent;
        }
        
        .header.scrolled {
            background: rgba(0, 0, 0, 0.95);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-subtle);
            padding: 10px 0;
        }
        
        .header .container {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        
        .logo {
            display: flex;
            align-items: center;
            gap: 14px;
        }
        
        .logo-img {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--text-muted);
        }
        
        .logo-text {
            font-family: var(--font-heading);
            font-size: 24px;
            font-weight: 700;
            color: var(--text-primary);
            letter-spacing: 1px;
            text-transform: uppercase;
        }
        
        .logo-text span {
            color: var(--text-muted);
        }
        
        .nav {
            display: flex;
            align-items: center;
            gap: 36px;
        }
        
        .nav a {
            font-size: 14px;
            font-weight: 500;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: var(--transition);
            position: relative;
        }
        
        .nav a::after {
            content: '';
            position: absolute;
            bottom: -4px;
            left: 0;
            width: 0;
            height: 2px;
            background: var(--text-primary);
            transition: var(--transition);
        }
        
        .nav a:hover {
            color: var(--text-primary);
        }
        
        .nav a:hover::after {
            width: 100%;
        }
        
        .nav a.active {
            color: var(--text-primary);
        }
        
        .nav a.active::after {
            width: 100%;
        }
        
        .hamburger {
            display: none;
            flex-direction: column;
            gap: 5px;
            background: none;
            border: none;
            cursor: pointer;
            padding: 4px;
        }
        
        .hamburger span {
            display: block;
            width: 28px;
            height: 2px;
            background: var(--text-primary);
            border-radius: 2px;
            transition: var(--transition);
        }
        
        .hamburger.active span:nth-child(1) {
            transform: rotate(45deg) translate(5px, 5px);
        }
        
        .hamburger.active span:nth-child(2) {
            opacity: 0;
            transform: translateX(-10px);
        }
        
        .hamburger.active span:nth-child(3) {
            transform: rotate(-45deg) translate(5px, -5px);
        }
        
        /* ============================
                   HERO - B&W
                ============================ */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            position: relative;
            background: var(--bg-dark);
            overflow: hidden;
            padding: 120px 0 80px;
        }
        
        .hero-bg-pattern {
            position: absolute;
            inset: 0;
            background-image: 
                radial-gradient(circle at 20% 50%, rgba(255,255,255,0.03) 0%, transparent 50%),
                radial-gradient(circle at 80% 20%, rgba(255,255,255,0.02) 0%, transparent 40%),
                radial-gradient(circle at 50% 80%, rgba(255,255,255,0.015) 0%, transparent 40%);
            pointer-events: none;
        }
        
        .hero-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: center;
            position: relative;
            z-index: 1;
        }
        
        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.08);
            padding: 6px 16px 6px 8px;
            border-radius: 50px;
            font-size: 12px;
            font-weight: 500;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 20px;
        }
        
        .hero-badge .dot {
            width: 8px;
            height: 8px;
            background: var(--text-primary);
            border-radius: 50%;
            animation: pulse-dot 1.5s infinite;
        }
        
        @keyframes pulse-dot {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.3; transform: scale(0.7); }
        }
        
        .hero h1 {
            font-family: var(--font-heading);
            font-size: clamp(40px, 6vw, 68px);
            font-weight: 700;
            color: var(--text-primary);
            line-height: 1.05;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 16px;
        }
        
        .hero h1 .highlight {
            color: var(--text-secondary);
        }
        
        .hero p {
            font-size: 18px;
            color: var(--text-secondary);
            max-width: 480px;
            margin-bottom: 32px;
            line-height: 1.8;
        }
        
        .hero-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 14px;
            margin-bottom: 0;
        }
        
        .hero-image {
            display: flex;
            justify-content: center;
            align-items: center;
        }
        
        .hero-image-wrapper {
            position: relative;
            width: 100%;
            max-width: 500px;
        }
        
        .hero-image-wrapper img {
            border-radius: var(--radius);
            box-shadow: 0 30px 80px rgba(0,0,0,0.8);
            border: 1px solid var(--border-subtle);
            width: 100%;
        }
        
        .hero-image-wrapper .floating-badge {
            position: absolute;
            bottom: -20px;
            right: -20px;
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            padding: 16px 20px;
            border-radius: var(--radius);
            box-shadow: var(--shadow-glow);
            text-align: center;
            min-width: 120px;
        }
        
        .hero-image-wrapper .floating-badge .big {
            font-family: var(--font-heading);
            font-size: 28px;
            font-weight: 700;
            color: var(--text-primary);
        }
        
        .hero-image-wrapper .floating-badge .small {
            font-size: 12px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        /* ============================
                   SOCIAL STRIP - B&W
                ============================ */
        .social-strip {
            background: var(--bg-card);
            border-top: 1px solid var(--border-subtle);
            border-bottom: 1px solid var(--border-subtle);
            padding: 16px 0;
        }
        
        .social-strip .container {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 16px;
        }
        
        .social-strip .label {
            font-size: 13px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        
        .social-strip .icons {
            display: flex;
            gap: 12px;
        }
        
        .social-strip .icons a {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: rgba(255,255,255,0.04);
            color: var(--text-secondary);
            font-size: 16px;
            transition: var(--transition);
        }
        
        .social-strip .icons a:hover {
            background: var(--text-primary);
            color: var(--text-dark);
            transform: translateY(-2px);
        }
        
        /* ============================
                   FEATURED EVENT - FIXED SIDE BY SIDE
                ============================ */
        .featured-event {
            padding: 80px 0;
            background: var(--bg-card);
        }
        
        .event-wrapper {
            display: flex;
            align-items: center;
            gap: 50px;
            max-width: 1100px;
            margin: 0 auto;
        }
        
        .event-image {
            flex: 0 0 40%;
            max-width: 40%;
        }
        
        .event-image img {
            border-radius: var(--radius);
            box-shadow: 0 20px 60px rgba(0,0,0,0.6);
            border: 1px solid var(--border-subtle);
            width: 100%;
            height: auto;
        }
        
        .event-content {
            flex: 1;
        }
        
        .event-content .tag {
            display: inline-block;
            background: var(--text-primary);
            color: var(--text-dark);
            font-family: var(--font-heading);
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
            padding: 4px 16px;
            border-radius: 2px;
            margin-bottom: 12px;
        }
        
        .event-content h2 {
            font-family: var(--font-heading);
            font-size: clamp(32px, 4vw, 44px);
            color: var(--text-primary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 12px;
            line-height: 1.1;
        }
        
        .event-content h2 .highlight {
            color: var(--text-secondary);
        }
        
        .event-content .description {
            color: var(--text-secondary);
            font-size: 17px;
            line-height: 1.8;
            margin-bottom: 24px;
        }
        
        .event-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 24px;
            margin-bottom: 28px;
        }
        
        .event-meta .item {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 14px;
            color: var(--text-secondary);
        }
        
        .event-meta .item i {
            color: var(--text-muted);
            font-size: 18px;
            width: 20px;
        }
        
        .event-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
        }
        
        /* ============================
                   ABOUT - B&W
                ============================ */
        .about {
            padding: 80px 0;
            background: var(--bg-dark);
        }
        
        .about-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: center;
        }
        
        .about-text .section-header {
            text-align: left;
            margin-bottom: 20px;
        }
        
        .about-text .section-header .line {
            margin: 12px 0 0;
        }
        
        .about-text p {
            color: var(--text-secondary);
            font-size: 17px;
            line-height: 1.9;
            margin-bottom: 16px;
        }
        
        .about-text .features {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px 24px;
            margin: 20px 0 28px;
        }
        
        .about-text .features li {
            display: flex;
            align-items: center;
            gap: 10px;
            color: var(--text-secondary);
            font-size: 15px;
        }
        
        .about-text .features li i {
            color: var(--text-muted);
            font-size: 14px;
        }
        
        .about-image img {
            border-radius: var(--radius);
            box-shadow: 0 20px 60px rgba(0,0,0,0.6);
            width: 100%;
            border: 1px solid var(--border-subtle);
            filter: grayscale(100%);
        }
        
        /* ============================
                   PROMO BANNER - B&W
                ============================ */
        .promo-banner {
            padding: 60px 0;
            background: var(--bg-light);
            text-align: center;
            position: relative;
            overflow: hidden;
            border-top: 1px solid var(--border-subtle);
            border-bottom: 1px solid var(--border-subtle);
        }
        
        .promo-banner::before {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
            pointer-events: none;
        }
        
        .promo-banner .container {
            position: relative;
            z-index: 1;
        }
        
        .promo-banner h2 {
            font-family: var(--font-heading);
            font-size: clamp(28px, 3.5vw, 38px);
            color: var(--text-primary);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }
        
        .promo-banner p {
            color: var(--text-secondary);
            font-size: 18px;
            max-width: 500px;
            margin: 0 auto 28px;
        }
        
        .promo-banner .actions {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 14px;
        }
        
        /* ============================
                   CONTACT - B&W
                ============================ */
        .contact {
            padding: 80px 0;
            background: var(--bg-card);
        }
        
        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: start;
        }
        
        .contact-info .info-item {
            display: flex;
            gap: 16px;
            margin-bottom: 24px;
        }
        
        .contact-info .info-item .icon {
            width: 48px;
            height: 48px;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(255,255,255,0.05);
            border-radius: 50%;
            color: var(--text-secondary);
            font-size: 20px;
            border: 1px solid var(--border-subtle);
        }
        
        .contact-info .info-item .label {
            font-size: 12px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 500;
        }
        
        .contact-info .info-item .value {
            color: var(--text-primary);
            font-weight: 500;
            font-size: 16px;
        }
        
        .contact-hours {
            background: var(--bg-dark);
            border-radius: var(--radius);
            padding: 24px 28px;
            margin-top: 16px;
            border: 1px solid var(--border-subtle);
        }
        
        .contact-hours h4 {
            font-family: var(--font-heading);
            color: var(--text-primary);
            font-size: 16px;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 12px;
        }
        
        .contact-hours .row {
            display: flex;
            justify-content: space-between;
            padding: 6px 0;
            font-size: 15px;
            color: var(--text-secondary);
            border-bottom: 1px solid var(--border-subtle);
        }
        
        .contact-hours .row:last-child {
            border-bottom: none;
        }
        
        .contact-visit-card {
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--bg-dark);
            border-radius: var(--radius);
            border: 1px solid var(--border-subtle);
            padding: 40px;
            text-align: center;
            min-height: 300px;
        }
        
        .contact-visit-card i {
            font-size: 48px;
            color: var(--text-muted);
            margin-bottom: 16px;
            display: block;
        }
        
        .contact-visit-card h3 {
            font-family: var(--font-heading);
            color: var(--text-primary);
            font-size: 24px;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }
        
        .contact-visit-card p {
            color: var(--text-muted);
            font-size: 16px;
            max-width: 300px;
            margin: 0 auto;
        }
        
        .contact-visit-card .btn {
            margin-top: 20px;
        }
        
        /* ============================
                   FOOTER - COMPACT HORIZONTAL LAYOUT
                ============================ */
        .footer {
            background: var(--bg-dark);
            border-top: 1px solid var(--border-subtle);
            padding: 40px 0 24px;
        }
        
        .footer-top {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: flex-start;
            gap: 30px 60px;
            padding-bottom: 24px;
            border-bottom: 1px solid var(--border-subtle);
        }
        
        .footer-brand {
            flex: 0 0 220px;
        }
        
        .footer-brand .logo {
            margin-bottom: 8px;
        }
        
        .footer-brand .logo-img {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--text-muted);
        }
        
        .footer-brand .logo-text {
            font-size: 20px;
        }
        
        .footer-brand p {
            font-size: 14px;
            color: var(--text-muted);
            line-height: 1.5;
        }
        
        .footer-links {
            display: flex;
            flex-wrap: wrap;
            gap: 40px 60px;
        }
        
        .footer-links .col h4 {
            font-family: var(--font-heading);
            color: var(--text-primary);
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 10px;
        }
        
        .footer-links .col ul li {
            margin-bottom: 4px;
        }
        
        .footer-links .col ul li a {
            font-size: 14px;
            color: var(--text-muted);
            transition: var(--transition);
        }
        
        .footer-links .col ul li a:hover {
            color: var(--text-primary);
        }
        
        .footer-bottom {
            padding-top: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
            font-size: 13px;
            color: var(--text-muted);
        }
        
        .footer-bottom .social {
            display: flex;
            gap: 8px;
        }
        
